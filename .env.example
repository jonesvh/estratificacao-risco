# =============================================================================
# Estratificação de Risco — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
#
#   cp .env.example .env
#   docker compose up -d
# =============================================================================

# ── Application mode ──────────────────────────────────────────────────────────
NODE_ENV=production

# ── HTTP port exposed by nginx (host port) ────────────────────────────────────
HTTP_PORT=80

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=estratificacao
POSTGRES_USER=eruser
# REQUIRED — change in production
# IMPORTANT: avoid @ and # — they break the DATABASE_URL parser.
# Use letters, digits, and safe special chars (!, _, -).
POSTGRES_PASSWORD=change_me_strong_password_123

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED — minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret_string_at_least_32_chars
JWT_EXPIRES_IN=8h

# ── Admin account (created on first startup, idempotent) ──────────────────────
# REQUIRED
ADMIN_EMAIL=admin@empresa.com
# REQUIRED — change before going live
ADMIN_PASSWORD=Admin@123456

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to the URL users will access the app from (browser origin).
# With nginx on port 80: http://localhost
# With a real domain:    https://app.empresa.com
CORS_ORIGIN=http://localhost

# ── Logging ───────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error
LOG_LEVEL=info
